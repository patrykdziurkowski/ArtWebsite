@using web.Features.ArtPieces.UploadArtPiece
@model UploadArtPieceModel

<div class="row justify-content-center">

    <div id="step-1" class="card border-0 shadow-sm">
        <div class="card-body text-center p-5">
            <h1 class="mb-4">Upload some art!</h1>
            <div class="upload-area">
                <i class="bi bi-cloud-upload fs-1 text-primary mb-3 d-block"></i>
                <label for="image-input" class="btn btn-primary btn-lg">
                    <i class="bi bi-image"></i> Choose an Image
                </label>
                <button type="button" id="blank-canvas-btn" class="btn btn-outline-secondary btn-lg ms-2">
                    <i class="bi bi-file-earmark-plus"></i> New
                </button>
                <input type="file" class="d-none" id="image-input" name="Image" accept="image/*" />
                <span id="image-input-error" class="text-danger small d-block mt-2"></span>
                <p class="text-muted mt-3 mb-0">Select an image or start with a blank canvas</p>
            </div>
        </div>
    </div>

    <div id="step-2" style="display: none;" class="h-100">
        <div class="card border-0 shadow-sm h-100 d-flex">
            <div class="card-header border-0 p-3">
                <h4 class="mb-0">Edit Your Art</h4>
            </div>
            <div class="card-body p-0 flex-grow-1" style="overflow:hidden;">
                <div id="image-editor-container"></div>
            </div>
            <div class="card-footer border-0 p-3 text-end">
                <button id="apply-edits" class="btn btn-primary btn-lg">
                    Apply Edits & Continue <i class="bi bi-arrow-right"></i>
                </button>
            </div>
        </div>
    </div>

    <div id="step-3" style="display: none;">
        <form id="upload-form" asp-action="Upload" method="POST" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            
            <div class="card border-0 shadow-sm">
                <div class="card-header border-0 p-3">
                    <h4 class="mb-0">Almost Done!</h4>
                </div>
                <div class="form-group d-none">
                    <label for="Image">Choose an image</label>
                    <input type="file" class="form-control" id="image-input-hidden" name="Image" accept="image/*" asp-for="Image" />
                    <span asp-validation-for="Image" class="text-danger"></span>
                </div>
                <div class="card-body p-4">
                    <div class="mb-4">
                        <label for="description-input" class="form-label fw-semibold">
                            Add a Description
                        </label>
                        <textarea class="form-control form-control-lg" 
                                    id="description-input" 
                                    name="Description" 
                                    rows="4"
                                    placeholder="Tell us about your art piece..."></textarea>
                        <span data-valmsg-for="Description" class="text-danger"></span>
                    </div>
                </div>
                <div class="card-footer border-0 p-3 text-end">
                    <button type="button" id="back-to-edit" class="btn btn-outline-secondary me-2">
                        <i class="bi bi-arrow-left"></i> Back to Edit
                    </button>
                    <button id="upload-submit" type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-upload"></i> Upload Art
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<style>
    .upload-area {
        padding: 3rem 1rem;
    }

    .upload-area label {
        cursor: pointer;
    }

    .main-buttons button {
        width: 4em !important;
    }

    .extended-buttons button {
        width: 4em !important;
    }

    #tip-container {
        display: none;
    }

    .row main {
        padding-top: 0 !important;
        padding-bottom: 0 !important;
    }

    main > div {
        height: calc(100vh - 60px);
    }

    #canvas-holder {
        display: block;
    }

    #toolbar {
        background-color: var(--bs-secondary-bg);
    }

    #toolbar button {
        background: none;
        color: var(--bs-body-color);
        fill: var(--bs-body-color);
        stroke: var(--bs-body-color);
    }

    #toolbar div button.active {
        border: 0.5em solid var(--bs-body-color);
    }

    #toolbar button path {
        fill: inherit !important;
    }

    #image-editor-container {
        position: relative;
    }

    #image-editor-container .toolpanel {
        background-color: var(--bs-secondary-bg);
        color: var(--bs-body-color);
        border-left: none;
        border-top: none;
        border-bottom: none;
    }

    #image-editor-container .toolpanel .tab-label,
    #image-editor-container .toolpanel .title {
        color: inherit;
    }

    #image-editor-container .toolpanel .custom-number-input {
        background-color: var(--bs-secondary-bg);
    }

    #image-editor-container .toolpanel input {
        border-radius: 0 !important;
        border: 2px solid var(--bs-body-color) !important;
    }
    
    #image-editor-container .toolpanel .custom-number-input button:first-child {
        border-top-right-radius: 0;
        border-bottom-right-radius: 0;
    }

    #image-editor-container .toolpanel .custom-number-input button:last-child {
        border-top-left-radius: 0;
        border-bottom-left-radius: 0;
    }

    #image-editor-container .floating-zoom-level-container {
        background-color: var(--bs-secondary-bg);
        z-index: 10;
        right: 1em;
        padding: 0.5em 1em;
        border-bottom: none;
    }

    #sp-container,
    .sp-picker-container,
    .sp-palette-container {
        background-color: var(--bs-body-bg);
    }

    input.sp-input {
        color: var(--bs-body-color);
    }

    .sp-container .sp-picker-container button {
        color: var(--bs-body-color);
    }

    .sp-palette span.sp-thumb-inner {
        border-radius: 0;
    }

    div.sp-container {
        border-radius: 0;
    }

    .toolpanel .content div.hide-show-handler {
        border-top-right-radius: 1em;
        border-bottom-right-radius: 1em;
        background-color: var(--bs-body-bg);
        border-left: none;
    }

    #shapes-panel svg * {
        stroke: var(--bs-body-color);
        color: var(--bs-body-color);
        fill: var(--bs-body-color);
    }

    #pan-tool i {
        vertical-align: middle;
        font-size: 22px;
    }
</style>

@section Scripts
{
    <link rel="stylesheet" href="~/lib/fabricjs-image-editor-origin/style.css">
    <script>
        jQuery.fn.outerHTML = function() {
            return jQuery('<div />').append(this.eq(0).clone()).html();
        };
        Number.prototype.countDecimals = function () {
            if(Math.floor(this.valueOf()) === this.valueOf()) return 0;
            return this.toString().split(".")[1].length || 0; 
        }
    </script>
    <script src="~/lib/fabricjs/fabric.min.js"></script>
    <script src="~/lib/spectrum/spectrum.min.js"></script>
    <link rel="stylesheet" type="text/css" href="~/lib/spectrum/spectrum.min.css">

    <script src="~/lib/fabricjs-image-editor-origin/grapick.min.js"></script>
    <link rel="stylesheet" href="~/lib/fabricjs-image-editor-origin/grapick.min.css">

    <script src="~/lib/fabricjs-image-editor-origin/undo-redo-stack.js"></script>

    <script src="~/lib/fabricjs-image-editor-origin/core.js"></script>
    <script src="~/lib/fabricjs-image-editor-origin/toolbar.js"></script>
    <script src="~/lib/fabricjs-image-editor-origin/canvas.js"></script>
    <script src="~/lib/fabricjs-image-editor-origin/shapes.js"></script>

    <script src="~/lib/fabricjs-image-editor-origin/freeDrawSettings.js"></script>
    <script src="~/lib/fabricjs-image-editor-origin/canvasSettings.js"></script>
    <script src="~/lib/fabricjs-image-editor-origin/selectionSettings.js"></script>

    <script src="~/lib/fabricjs-image-editor-origin/drawingLine.js"></script>
    <script src="~/lib/fabricjs-image-editor-origin/drawingPath.js"></script>
    <script src="~/lib/fabricjs-image-editor-origin/drawingText.js"></script>
    <script src="~/lib/fabricjs-image-editor-origin/tip.js"></script>
    <script src="~/lib/fabricjs-image-editor-origin/upload.js"></script>
    <script src="~/lib/fabricjs-image-editor-origin/copyPaste.js"></script>

    <script src="~/lib/fabricjs-image-editor-origin/utils.js"></script>
    <script src="~/lib/fabricjs-image-editor-origin/zoom.js"></script>
    <script src="~/lib/fabricjs-image-editor-origin/saveInBrowser.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            let validImageLoaded = false;
            
            const step1 = document.getElementById('step-1');
            const step2 = document.getElementById('step-2');
            const step3 = document.getElementById('step-3');

            const buttons = [
                'select',
                'shapes',
                'draw',
                'line',
                'path',
                'textbox',
                'background',
                'undo',
                'redo',
                'download',
            ];

            let imgEditor = new ImageEditor('#image-editor-container', buttons, []);

            let isUndoRedoing = false;

            imgEditor.canvas.on('object:added', (e) => {
                const type = e.target?.type;
                if (type === 'textbox' || type === 'i-text' || type === 'text') {
                    document.querySelector('#image-editor-container #select')?.click();
                }
                
                if (!isUndoRedoing && type === 'path') {
                    imgEditor.history.push(JSON.stringify(imgEditor.canvas.toJSON()));
                }
            });

            imgEditor.canvas.on('object:removed', () => {
                if (isUndoRedoing) return;
                imgEditor.history.push(JSON.stringify(imgEditor.canvas.toJSON()));
            });

            imgEditor.undo = () => {
                try {
                    const undoList = imgEditor.history.getValues().undo;
                    if (undoList.length > 1) {
                        imgEditor.history.undo();
                        const newTop = imgEditor.history.getValues().undo;
                        const current = newTop[newTop.length - 1];
                        if (current) {
                            isUndoRedoing = true;
                            imgEditor.canvas.loadFromJSON(JSON.parse(current), () => {
                                imgEditor.canvas.renderAll();
                                isUndoRedoing = false;
                            });
                        }
                    }
                } catch (_) { console.error("undo failed"); }
            };

            imgEditor.redo = () => {
                try {
                    const redoList = imgEditor.history.getValues().redo;
                    if (redoList.length) {
                        const current = redoList[redoList.length - 1];
                        imgEditor.history.redo();
                        if (current) {
                            isUndoRedoing = true;
                            imgEditor.canvas.loadFromJSON(JSON.parse(current), () => {
                                imgEditor.canvas.renderAll();
                                isUndoRedoing = false;
                            });
                        }
                    }
                } catch (_) { console.error("redo failed"); }
            };

            const canvasHolder = document.getElementById('canvas-holder');

            document.querySelector("#image-editor-container #select").classList.add('active');

            const toolbar = document.querySelector('#toolbar .main-buttons');
            const panBtn = document.createElement('button');
            panBtn.id = 'pan-tool';
            panBtn.title = 'Pan';
            panBtn.innerHTML = '<i class="bi bi-arrows-move"></i>';
            toolbar.appendChild(panBtn);

            let isPanMode = false;
            let isPanning = false;
            let lastPosX = 0;
            let lastPosY = 0;

            function deactivatePan() {
                isPanMode = false;
                isPanning = false;
                panBtn.classList.remove('active');
            }

            function activatePan() {
                isPanMode = true;
                panBtn.classList.add('active');
                document.querySelectorAll('#toolbar button:not(#pan-tool)').forEach(btn => btn.classList.remove('active'));
                imgEditor.canvas.isDrawingMode = false;
                imgEditor.canvas.selection = false;
                imgEditor.canvas.forEachObject(obj => obj.selectable = false);
            }

            panBtn.addEventListener('click', () => {
                isPanMode ? deactivatePan() : activatePan();
            });

            document.querySelector('#toolbar').addEventListener('click', (e) => {
                const btn = e.target.closest('button');
                if (btn && btn.id !== 'pan-tool') {
                    deactivatePan();
                }
            });

            canvasHolder.addEventListener('mousedown', (e) => {
                if (!isPanMode) return;
                isPanning = true;
                lastPosX = e.clientX;
                lastPosY = e.clientY;
                e.preventDefault();
            });

            canvasHolder.addEventListener('mousemove', (e) => {
                if (!isPanMode || !isPanning) return;
                canvasHolder.scrollLeft -= e.clientX - lastPosX;
                canvasHolder.scrollTop -= e.clientY - lastPosY;
                lastPosX = e.clientX;
                lastPosY = e.clientY;
            });

            document.addEventListener('mouseup', () => isPanning = false);

            canvasHolder.addEventListener('touchstart', (e) => {
                if (!isPanMode || e.touches.length !== 1) return;
                isPanning = true;
                lastPosX = e.touches[0].clientX;
                lastPosY = e.touches[0].clientY;
            }, { passive: true });

            canvasHolder.addEventListener('touchmove', (e) => {
                if (!isPanMode || !isPanning || e.touches.length !== 1) return;
                canvasHolder.scrollLeft -= e.touches[0].clientX - lastPosX;
                canvasHolder.scrollTop -= e.touches[0].clientY - lastPosY;
                lastPosX = e.touches[0].clientX;
                lastPosY = e.touches[0].clientY;
                e.preventDefault();
            }, { passive: false });

            document.addEventListener('touchend', () => isPanning = false);

            canvasHolder.addEventListener('contextmenu', (e) => e.preventDefault());

            document.querySelector('#image-input').onchange = async (e) => {
                const file = e.target.files[0];
                if (!file) return;

                const imageError = document.getElementById('image-input-error');
                const allowedTypes = ['image/jpeg', 'image/png', 'image/webp'];
                if (!allowedTypes.includes(file.type)) {
                    imageError.innerText = 'Please select a valid image file (JPEG, PNG, or WebP).';
                    e.target.value = '';
                    return;
                }

                imageError.innerText = '';

                const reader = new FileReader();
                reader.onload = function(event) {
                    fabric.Image.fromURL(event.target.result, function(img) {
                        const canvas = imgEditor.canvas;
                        
                        document.querySelector('#input-height').value = img.height;
                        $(document.querySelector('#input-height')).change();
                        document.querySelector('#input-width').value = img.width;
                        $(document.querySelector('#input-width')).change();

                        canvas.setBackgroundImage(img, canvas.renderAll.bind(canvas));
                        imgEditor.history.clear();
                        imgEditor.history.push(JSON.stringify(imgEditor.canvas.toJSON()));

                        validImageLoaded = true;
                        step1.style.display = 'none';
                        step2.style.display = 'block';
                    });
                };
                reader.readAsDataURL(file);
                
            };

            document.getElementById('blank-canvas-btn').onclick = () => {
                const canvas = imgEditor.canvas;
                
                document.querySelector('#input-height').value = 720;
                $(document.querySelector('#input-height')).change();
                document.querySelector('#input-width').value = 1280;
                $(document.querySelector('#input-width')).change();

                canvas.backgroundColor = 'white';
                canvas.renderAll();
                imgEditor.history.clear();
                imgEditor.history.push(JSON.stringify(imgEditor.canvas.toJSON()));

                validImageLoaded = true;
                step1.style.display = 'none';
                step2.style.display = 'block';
            };
            
            document.getElementById('apply-edits').onclick = () => {
                step2.style.display = 'none';
                step3.style.display = 'block';
            };

            document.getElementById('back-to-edit').onclick = () => {
                step3.style.display = 'none';
                step2.style.display = 'block';
            };

            document.querySelector('#upload-form').onsubmit = async (e) => {
                e.preventDefault();

                if (!validImageLoaded) {
                    alert('Please upload an image or create a blank canvas first');
                    return;
                }

                document.querySelector('#input-zoom-level').value = 1;
                $(document.querySelector('#input-zoom-level')).change();

                const dataURL = imgEditor.canvas.toDataURL({ format: 'png', quality: 1 });
                const blob = await (await fetch(dataURL)).blob();
                const newFile = new File([blob], 'edited-image.png', { type: 'image/png' });

                const container = new DataTransfer();
                container.items.add(newFile);
                document.querySelector('#image-input-hidden').files = container.files;

                const formData = new FormData(e.target);

                const response = await fetch("/api/artpieces", {
                    method: 'POST',
                    body: formData,
                });

                if (!response.ok) {
                    const data = await response.json();
                    const descriptionSpan = document.querySelector('span[data-valmsg-for="Description"]');
                    descriptionSpan.innerText = data.errors?.Description?.[0] ?? 'Please provide a description.';
                    return;
                }

                window.location.href = response.url;
            };
        });
    </script>
}